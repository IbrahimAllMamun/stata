# URL of your STATA Express backend API
VITE_API_URL=http://localhost:3000/api

# Base URL for serving uploaded files (photos, images).
# In dev this is automatically derived from VITE_API_URL (strips trailing /api).
# In production, set this explicitly to avoid issues with domains containing "api":

VITE_UPLOAD_URL=http://localhost:3000

# Public URL of the frontend — used to embed the logo in outgoing emails.
# In dev this is auto-detected from window.location, so you can leave it blank.
# In production set it to your actual domain, e.g. https://stata-alumni.com
VITE_FRONTEND_URL=https://yourdomain.com