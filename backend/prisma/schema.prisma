// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                   String           @id @default(uuid())
  batch                Int
  full_name            String
  email                String           @unique
  phone_number         String
  alternative_phone    String?
  job_title            String?
  organisation         String?
  organisation_address String?
  notify_events        Boolean
  status               MemberStatus     @default(PENDING)
  created_at           DateTime         @default(now())

  committee_members    CommitteeMember[]

  @@index([batch])
  @@index([email])
  @@index([status])
  @@map("members")
}

enum MemberStatus {
  PENDING
  APPROVED
  ARCHIVED
}

model Admin {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  role       String   @default("admin")
  created_at DateTime @default(now())

  posts  Post[]
  events Event[]

  @@map("admins")
}

model Committee {
  id          String   @id @default(uuid())
  acting_year Int      @unique
  created_at  DateTime @default(now())

  members CommitteeMember[]

  @@map("committees")
}

model CommitteeMember {
  id           String    @id @default(uuid())
  committee_id String
  member_id    String
  position     Position
  image_url    String
  created_at   DateTime  @default(now())

  committee Committee @relation(fields: [committee_id], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([committee_id, position])
  @@map("committee_members")
}

enum Position {
  PRESIDENT
  GENERAL_SECRETARY
}

model Post {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  content      String
  cover_image  String?
  published    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  created_by   String

  admin Admin @relation(fields: [created_by], references: [id])

  @@index([slug])
  @@index([created_at])
  @@map("posts")
}

model Event {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  event_date   DateTime
  location     String?
  banner_image String?
  is_upcoming  Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  created_by   String

  admin Admin @relation(fields: [created_by], references: [id])

  @@index([slug])
  @@index([event_date])
  @@index([is_upcoming])
  @@map("events")
}

model ContactMessage {
  id         String        @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String
  status     MessageStatus @default(UNREAD)
  created_at DateTime      @default(now())

  @@index([status])
  @@index([created_at])
  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}
