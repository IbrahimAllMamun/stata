// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id                   String           @id @default(uuid())
  batch                Int
  full_name            String
  email                String           @unique
  phone_number         String
  alternative_phone    String?
  job_title            String?
  organisation         String?
  organisation_address String?
  notify_events        Boolean
  status               MemberStatus     @default(PENDING)
  created_at           DateTime         @default(now())

  committee_members    CommitteeMember[]

  @@index([batch])
  @@index([email])
  @@index([status])
  @@map("members")
}

enum MemberStatus {
  PENDING
  APPROVED
  ARCHIVED
}

model Admin {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  role       String   @default("admin")
  created_at DateTime @default(now())

  posts          Post[]
  events         Event[]
  gallery_photos GalleryPhoto[]

  @@map("admins")
}

model Committee {
  id          String   @id @default(uuid())
  acting_year Int      @unique
  created_at  DateTime @default(now())

  members CommitteeMember[]

  @@map("committees")
}

model CommitteeMember {
  id           String    @id @default(uuid())
  committee_id String
  member_id    String
  position     Position
  image_url    String
  created_at   DateTime  @default(now())

  committee Committee @relation(fields: [committee_id], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([committee_id, position])
  @@map("committee_members")
}

enum Position {
  PRESIDENT
  GENERAL_SECRETARY
}

model Post {
  id           String     @id @default(uuid())
  title        String
  slug         String     @unique
  content      String
  cover_image  String?
  status       PostStatus @default(PENDING)
  published    Boolean    @default(false)
  author_name  String
  author_batch Int
  created_by   String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  admin Admin? @relation(fields: [created_by], references: [id])

  @@index([slug])
  @@index([status])
  @@index([created_at])
  @@map("posts")
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

model Event {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  event_date   DateTime
  location     String?
  banner_image String?
  is_upcoming  Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  created_by   String

  admin Admin @relation(fields: [created_by], references: [id])

  @@index([slug])
  @@index([event_date])
  @@index([is_upcoming])
  @@map("events")
}

model ContactMessage {
  id          String        @id @default(uuid())
  name        String
  email       String
  subject     String
  message     String
  batch       Int?
  designation String?
  status      MessageStatus @default(UNREAD)
  featured    Boolean       @default(false)
  created_at  DateTime      @default(now())

  @@index([status])
  @@index([featured])
  @@index([created_at])
  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

model GalleryPhoto {
  id          String   @id @default(uuid())
  image_url   String
  caption     String?
  moment_date DateTime
  created_by  String
  created_at  DateTime @default(now())

  admin Admin @relation(fields: [created_by], references: [id])

  @@index([moment_date])
  @@index([created_at])
  @@map("gallery_photos")
}

// ── ASPL ─────────────────────────────────────────────────────────────────────

enum AsplSport {
  FOOTBALL
  CRICKET
  @@map("aspl_sport")
}

enum AsplSeasonStatus {
  DRAFT
  ACTIVE
  COMPLETED
  @@map("aspl_season_status")
}

enum AsplRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  @@map("aspl_registration_status")
}

model AsplSeason {
  id               Int              @id @default(autoincrement())
  name             String           @db.VarChar(100)
  sport            AsplSport
  status           AsplSeasonStatus @default(DRAFT)
  max_squad_size   Int              @default(15)
  min_squad_size   Int              @default(11)
  min_bid_price    Int              @default(20)
  starting_balance Int              @default(1000)
  total_players    Int              @default(0)
  registration_open Boolean         @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  teams   AsplTeam[]
  players AsplPlayer[]
  registrations AsplRegistration[]

  @@map("aspl_seasons")
}

model AsplRegistration {
  id               Int                    @id @default(autoincrement())
  season_id        Int
  email            String                 @db.VarChar(255)
  full_name        String                 @db.VarChar(100)
  batch            Int
  playing_position String                 @db.VarChar(20)
  phone            String                 @db.VarChar(20)
  photo_url        String?
  status           AsplRegistrationStatus @default(PENDING)
  conflict_note    String?                // set when overwriting existing registration
  admin_note       String?                // admin rejection/approval note
  player_sl        Int?                   // set when approved → links to AsplPlayer
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt

  season AsplSeason @relation(fields: [season_id], references: [id], onDelete: Cascade)

  @@unique([email, season_id])
  @@map("aspl_registrations")
}

model AsplPlayer {
  sl               Int     @id @unique @map("sl")
  season_id        Int
  name             String  @db.VarChar(100)
  batch            Int
  playing_position String  @db.VarChar(20)
  email            String? @db.VarChar(255)
  phone            String? @db.VarChar(20)
  photo_url        String?
  status           Boolean @default(false)
  randomized       Boolean @default(false)

  season       AsplSeason       @relation(fields: [season_id], references: [id], onDelete: Cascade)
  team_players AsplTeamPlayer[]

  @@map("aspl_players")
}

model AsplTeam {
  id         Int    @id @default(autoincrement())
  season_id  Int
  owner_name String @db.VarChar(100)
  team_name  String @db.VarChar(255)
  logo_url   String?
  color      String @default("#2F5BEA") @db.VarChar(7)
  balance    Int

  season       AsplSeason       @relation(fields: [season_id], references: [id], onDelete: Cascade)
  team_players AsplTeamPlayer[]

  @@map("aspl_teams")
}

model AsplTeamPlayer {
  id        Int @id @default(autoincrement())
  team_id   Int
  player_sl Int
  price     Int

  player AsplPlayer @relation(fields: [player_sl], references: [sl], onDelete: Cascade)
  team   AsplTeam   @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([player_sl, team_id])
  @@map("aspl_team_players")
}
