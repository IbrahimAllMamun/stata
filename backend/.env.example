DATABASE_URL="postgresql://user:password@localhost:5432/stata_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
MAX_FILE_SIZE=2097152
UPLOAD_PATH=uploads
ALLOWED_ORIGINS=http://localhost:5173

