DATABASE_URL="postgresql://user:password@localhost:5432/stata_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
MAX_FILE_SIZE=2097152
UPLOAD_PATH=uploads
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
SEED_ADMIN_USERNAME="mimamun"
SEED_ADMIN_PASSWORD="mimamun@5822"
# ── Email / SMTP ───────────────────────────────────────────────────────────────
# The address that campaign emails are sent FROM (required)
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=STATA

# SMTP server credentials – examples below cover common providers:
#
# Gmail (App Password):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=you@gmail.com   SMTP_PASS=<16-char app password>
#
# Outlook / Office 365:
#   SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_SECURE=false
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=apikey             SMTP_PASS=<sendgrid API key>
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=postmaster@mg.yourdomain.com  SMTP_PASS=<mailgun SMTP password>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=no-reply@stataisrt.org
SMTP_PASS=<password for no-reply@stataisrt.org>


# Individual email account (send + receive from info@)
IMAP_HOST=stataisrt.org
IMAP_PORT=993
INFO_EMAIL=info@stataisrt.org
INFO_EMAIL_PASS=<password for info@stataisrt.org>